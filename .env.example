# Copy to .env and fill in. .env is gitignored — never commit it.
# Every value is optional; tools whose data source isn't configured return a
# clear "not configured" message instead of failing the whole server.

# ─────────────── Google auth — OAuth (covers GSC + GA4 + GBP) ───────────────
# Create a Desktop-app OAuth client (SETUP.md → Phase 2), put its id/secret here,
# then run `npm run auth` to fill GOOGLE_OAUTH_REFRESH_TOKEN.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Search Console property. URL-prefix form (with trailing slash) OR domain form:
#   https://example.com/   |   sc-domain:example.com
GSC_SITE_URL=https://example.com/

# GA4 default property — OPTIONAL. The MCP manages MULTIPLE GA4 properties + apps:
# leave blank and Claude lists them all (ga4_account_summaries) and targets any by
# passing propertyId per call. Set this only as a convenience default for your main
# property (the NUMERIC id, NOT the "G-XXXX" measurement id).
GA4_PROPERTY_ID=

# Google Business Profile account, e.g. accounts/1234567890.
# Only works AFTER Google approves Business Profile API access (allowlist form).
GBP_ACCOUNT_ID=

# ─────────────────────────── Meta ───────────────────────────
# Business-Manager SYSTEM USER token (long-lived). Scopes — read: read_insights +
# pages_read_engagement + ads_read. Manage (tidy ads/audiences/pages): ads_management
# + business_management + pages_manage_metadata. (Own-asset management works with
# Standard Access; advanced use needs Meta App Review.) See SETUP.md Phase 3.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_API_VERSION=v22.0
